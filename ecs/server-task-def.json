{
  "family": "acr-server",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:nhà cung cấp dịch vụ AI:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:nhà cung cấp dịch vụ AI:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": claude-opus-4.8,
      "environment": claude-opus-4.8,
      "secrets": claude-opus-4.8,
      "healthCheck": {
        "command": ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:3001/api/v1/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "startPeriod": 60,
        "retries": 3
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/acr-server",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "server"
        }
      }
    }
  ]
}
