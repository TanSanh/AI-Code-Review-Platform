{
  "family": "acr-server",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::679930074514:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::679930074514:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "acr-server",
      "image": "679930074514.dkr.ecr.ap-southeast-1.amazonaws.com/acr-server:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [],
      "secrets": [],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget --no-verbose --tries=1 --spider http://localhost:3001/api/v1/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "startPeriod": 60,
        "retries": 3
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/acr-server",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "server"
        }
      }
    }
  ]
}