{
  "family": "acr-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::679930074514:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::679930074514:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "acr-web",
      "image": "679930074514.dkr.ecr.ap-southeast-1.amazonaws.com/acr-web:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "NEXT_TELEMETRY_DISABLED", "value": "1" },
        { "name": "NEXT_PUBLIC_APP_NAME", "value": "AI Code Review" }
      ],
     "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"require('http').get('http://127.0.0.1:3000', () => process.exit(0)).on('error', () => process.exit(1))\""
        ],
        "interval": 30,
        "timeout": 5,
        "startPeriod": 60,
        "retries": 3
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/acr-web",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "web"
        }
      }
    }
  ]
}